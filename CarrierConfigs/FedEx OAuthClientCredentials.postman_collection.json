{
  "info": {
    "_postman_id": "5e9f6e17-2973-42a0-abd4-7ace9e159e42",
    "name": "FedEx OAuthClientCredentials",
    "description": "FedEx OAuth 2.0 Authorization API - Use this to obtain bearer tokens for authenticating FedEx API requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "8255341",
    "_collection_link": "https://go.postman.co/collection/8255341-5e9f6e17-2973-42a0-abd4-7ace9e159e42?source=collection_link"
  },
  "item": [
    {
      "name": "Get OAuth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "if (jsonData.access_token) {",
              "    // Save to global variable so all collections can access it",
              "    pm.globals.set(\"fedex_access_token\", jsonData.access_token);",
              "    pm.collectionVariables.set(\"fedex_access_token\", jsonData.access_token);",
              "    console.log(\"Access token saved to globals and collection variables\");",
              "}",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has access_token\", function () {",
              "    pm.expect(jsonData).to.have.property('access_token');",
              "});",
              "",
              "pm.test(\"Token type is bearer\", function () {",
              "    pm.expect(jsonData.token_type).to.eql('bearer');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "type": "text"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials",
              "description": "Type of customer requesting the OAuth token. Use 'client_credentials' for standard API access.",
              "type": "text"
            },
            {
              "key": "client_id",
              "value": "{{fedex_client_id}}",
              "description": "Your FedEx API Key from the Developer Portal",
              "type": "text"
            },
            {
              "key": "client_secret",
              "value": "{{fedex_client_secret}}",
              "description": "Your FedEx Secret Key from the Developer Portal",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{fedex_base_url}}/oauth/token",
          "host": [
            "{{fedex_base_url}}"
          ],
          "path": [
            "oauth",
            "token"
          ]
        },
        "description": "Use this endpoint to request the OAuth token (bearer token) to authorize your application to access FedEx resources."
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "fedex_base_url",
      "value": "https://apis-sandbox.fedex.com"
    },
    {
      "key": "fedex_client_id",
      "value": "REPLACE_WITH_YOUR_FEDEX_CLIENT_ID"
    },
    {
      "key": "fedex_client_secret",
      "value": "REPLACE_WITH_YOUR_FEDEX_CLIENT_SECRET"
    },
    {
      "key": "fedex_access_token",
      "value": "WILL_BE_AUTO_POPULATED"
    }
  ]
}