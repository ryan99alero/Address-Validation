{
  "info": {
    "_postman_id": "28d5c40e-eb64-40fd-b862-9102897becbe",
    "name": "UPS OAuthClientCredentials",
    "description": "UPS OAuth 2.0 Client Credentials API - Use this to obtain bearer tokens for authenticating UPS API requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "8255341",
    "_collection_link": "https://go.postman.co/collection/8255341-28d5c40e-eb64-40fd-b862-9102897becbe?source=collection_link"
  },
  "item": [
    {
      "name": "Get OAuth Token",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();",
              "",
              "if (jsonData.access_token) {",
              "    pm.globals.set(\"ups_access_token\", jsonData.access_token);",
              "    pm.collectionVariables.set(\"ups_access_token\", jsonData.access_token);",
              "    console.log(\"UPS Access token saved to globals and collection variables\");",
              "}",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has access_token\", function () {",
              "    pm.expect(jsonData).to.have.property('access_token');",
              "});",
              "",
              "pm.test(\"Token type is Bearer\", function () {",
              "    pm.expect(jsonData.token_type).to.eql('Bearer');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            {
              "key": "username",
              "value": "{{ups_client_id}}",
              "type": "string"
            },
            {
              "key": "password",
              "value": "{{ups_client_secret}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded",
            "type": "text"
          },
          {
            "key": "x-merchant-id",
            "value": "{{ups_account_number}}",
            "description": "Your 6-digit UPS account number (optional)",
            "type": "text"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            {
              "key": "grant_type",
              "value": "client_credentials",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{ups_base_url}}/security/v1/oauth/token",
          "host": [
            "{{ups_base_url}}"
          ],
          "path": [
            "security",
            "v1",
            "oauth",
            "token"
          ]
        },
        "description": "Use this endpoint to request the OAuth token (bearer token) to authorize your application to access UPS resources.\n\nUPS uses Basic Auth with your Client ID as username and Client Secret as password."
      },
      "response": []
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "packages": {},
        "requests": {},
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "ups_base_url",
      "value": "https://wwwcie.ups.com"
    },
    {
      "key": "ups_client_id",
      "value": "REPLACE_WITH_YOUR_UPS_CLIENT_ID"
    },
    {
      "key": "ups_client_secret",
      "value": "REPLACE_WITH_YOUR_UPS_CLIENT_SECRET"
    },
    {
      "key": "ups_account_number",
      "value": "REPLACE_WITH_YOUR_6_DIGIT_UPS_ACCOUNT"
    },
    {
      "key": "ups_access_token",
      "value": "WILL_BE_AUTO_POPULATED"
    }
  ]
}