  "item": [
    {
      "name": "Transit Times",
      "item": [
        {
          "name": "Get Transit Times - Domestic Ground",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var token = pm.collectionVariables.get(\"fedex_access_token\");",
                  "if (!token || token === \"WILL_BE_AUTO_POPULATED\") {",
                  "    var globalToken = pm.globals.get(\"fedex_access_token\");",
                  "    if (globalToken) {",
                  "        pm.collectionVariables.set(\"fedex_access_token\", globalToken);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has output\", function () {",
                  "    pm.expect(jsonData).to.have.property('output');",
                  "});",
                  "",
                  "pm.test(\"Response has transitTimes\", function () {",
                  "    pm.expect(jsonData.output).to.have.property('transitTimes');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
