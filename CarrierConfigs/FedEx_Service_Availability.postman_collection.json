        {
          "name": "Get Transit Times - With Ship Date",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var token = pm.collectionVariables.get(\"fedex_access_token\");",
                  "if (!token || token === \"WILL_BE_AUTO_POPULATED\") {",
                  "    var globalToken = pm.globals.get(\"fedex_access_token\");",
                  "    if (globalToken) {",
                  "        pm.collectionVariables.set(\"fedex_access_token\", globalToken);",
                  "    }",
                  "}",
                  "",
                  "// Set ship date to tomorrow",
                  "var tomorrow = new Date();",
                  "tomorrow.setDate(tomorrow.getDate() + 1);",
                  "var shipDate = tomorrow.toISOString().split('T')[0];",
                  "pm.collectionVariables.set(\"ship_date\", shipDate);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has output\", function () {",
                  "    pm.expect(jsonData).to.have.property('output');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
